# ============================================================
# Photo Concern Website - local .env (copy to .env and fill in)
# ============================================================

# ----- Server -----
NODE_ENV=development
PORT=3000

# ----- Session -----
# Generate a long random string. Anything 32+ chars works.
SESSION_SECRET=replace-me-with-a-long-random-string

# ----- MongoDB -----
# Option A (easy): MongoDB Atlas free tier
#   1. https://www.mongodb.com/cloud/atlas → create free M0 cluster
#   2. Database Access → add a user with password
#   3. Network Access → allow your IP (or 0.0.0.0/0 for testing)
#   4. Click "Connect" → "Drivers" → copy the connection string
# Option B (local): install MongoDB Community Edition, then:
#   atlas_url=mongodb://127.0.0.1:27017/photoconcern
atlas_url=mongodb://127.0.0.1:27017/photoconcern

# ----- Storage backend for uploaded design photos -----
# "drive" -> Google Drive (photoconcern65@gmail.com) [DEFAULT]
# "r2"    -> Cloudflare R2 (legacy)
STORAGE_BACKEND=drive

# ----- Google Drive service account -----
# 1. https://console.cloud.google.com → create project
# 2. APIs & Services → Enable "Google Drive API"
# 3. IAM & Admin → Service Accounts → Create
# 4. Keys → Add Key → JSON → save to ./config/service-account.json
# 5. In Drive (logged in as photoconcern65@gmail.com), create folder
#    "Online Orders", right-click → Share → paste the service account's
#    client_email (looks like xxxx@xxxx.iam.gserviceaccount.com), give
#    Editor access.
GOOGLE_SERVICE_ACCOUNT_KEYFILE=./config/service-account.json
DRIVE_ROOT_FOLDER_NAME=Online Orders

# ----- Google Sign-In (customer login) -----
# Create an OAuth 2.0 Client (type: Web application) at:
#   https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:3000 (+ your prod domain)
# Paste the resulting Client ID below.
GOOGLE_CLIENT_ID=

# ----- Fonepay Dynamic QR -----
# Use "test" until you have real merchant credentials from Fonepay.
FONEPAY_MODE=test
FONEPAY_MERCHANT_CODE=
FONEPAY_USERNAME=
FONEPAY_PASSWORD=
FONEPAY_SECRET_KEY=
FONEPAY_API_BASE=https://merchantapi.fonepay.com

# ----- Cloudflare R2 (only needed if STORAGE_BACKEND=r2) -----
ENDPOINTS_URL=
Access_Key_ID=
SECRET_ACCESS_KEY=
bucket_name=
R2_PUBLIC_URL=

# ----- Email (contact form, used by services/email.services.js) -----
EMAIL_USER=
EMAIL_PASS=

# ----- Twilio WhatsApp (admin notifications, optional) -----
# If left blank, WhatsApp notifications silently fail (orders still save).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ADMIN_WHATSAPP=

# ----- Admin auto-seed (creates a superadmin on first boot if no admins) -----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
